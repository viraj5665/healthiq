# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://healthiq:healthiq_password@localhost:5440/healthiq_db
# Railway provides this automatically as $DATABASE_URL when you add the Postgres plugin

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for NLP Agent (/nlp) and Reporting Agent (/reports/generate)
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ── FHIR (optional) ───────────────────────────────────────────────────────────
# Live FHIR R4 server; defaults to public HAPI sandbox
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4

# ── CORS (production only) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins beyond localhost dev defaults
# Example: CORS_ORIGINS=https://healthiq.vercel.app
CORS_ORIGINS=
